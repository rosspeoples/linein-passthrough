#!/usr/bin/env bash
set -euo pipefail

STATE_DIR=${XDG_STATE_HOME:-"${HOME}/.local/state"}/linein-passthrough
STATE_FILE=${STATE_DIR}/state.env
CONFIG_DIR=${XDG_CONFIG_HOME:-"${HOME}/.config"}/pipewire/pipewire.conf.d
CONFIG_FILE=${CONFIG_DIR}/90-linein-passthrough.conf
TMP_FILE=${STATE_DIR}/90-linein-passthrough.conf.tmp
ACTIVATE=0
VISIBLE_SINK_NAME=linein_passthrough.sink
FEED_CAPTURE_NAME=linein_passthrough.feed.capture
FEED_PLAYBACK_NAME=linein_passthrough.feed.playback
DIRECT_CAPTURE_NAME=linein_passthrough.direct.capture
DIRECT_PLAYBACK_NAME=linein_passthrough.direct.playback
VISIBLE_SINK_NICK='Line-In Passthrough'

usage() {
  cat <<'EOF'
Usage: linein-passthrough-refresh [--activate]

Detects a suitable line-in source and writes the persistent PipeWire loopback config.
The generated config creates a visible virtual sink named Line-In Passthrough.
When --activate is given, PipeWire and WirePlumber are restarted if the config changed.
EOF
}

while (($# > 0)); do
  case "$1" in
    --activate)
      ACTIVATE=1
      ;;
    -h|--help)
      usage
      exit 0
      ;;
    *)
      printf 'Unknown option: %s\n' "$1" >&2
      usage >&2
      exit 1
      ;;
  esac
  shift
done

require_cmd() {
  local cmd=$1
  if ! command -v "$cmd" >/dev/null 2>&1; then
    printf 'Missing required command: %s\n' "$cmd" >&2
    exit 1
  fi
}

require_cmd pw-dump
require_cmd wpctl
require_cmd jq
require_cmd systemctl
require_cmd pactl

mkdir -p "$STATE_DIR" "$CONFIG_DIR"

pw_dump=$(pw-dump)

nodes_json=$(
  jq -c '[.[] | select(.type == "PipeWire:Interface:Node") | {
    id: .id,
    name: (.info.props["node.name"] // ""),
    nick: (.info.props["node.nick"] // .info.props["node.description"] // ""),
    desc: (.info.props["node.description"] // ""),
    media_class: (.info.props["media.class"] // ""),
    device_id: (.info.props["device.id"] // 0),
    device_class: (.info.props["device.class"] // ""),
    object_path: (.info.props["object.path"] // ""),
    card_profile: (.info.props["device.profile.description"] // ""),
    api: (.info.props["device.api"] // ""),
    factory: (.info.props["factory.name"] // "")
  }]' <<<"$pw_dump"
)

linein_device_ids=$(
  jq -cr '[.[]
    | select(.type == "PipeWire:Interface:Device")
    | . as $device
    | ($device.info.params.Route // [])[]?
    | select(
        .direction == "Input" and
        (
          (.name | tostring | test("linein|line-in"; "i")) or
          (.description | tostring | test("line.?in"; "i"))
        ) and
        (.available == "yes")
      )
    | ($device.id | tonumber)
  ] | unique' <<<"$pw_dump"
)

linein=$(
  jq -cr '
    map(select(
      .media_class == "Audio/Source" and
      (.device_id as $device_id | $linein_device_ids | index($device_id))
    ))
    | sort_by(.name)
    | .[0] // empty
  ' --argjson linein_device_ids "$linein_device_ids" <<<"$nodes_json"
)

if [[ -z "$linein" ]]; then
  linein=$(
    jq -cr '
      map(select(
        .media_class == "Audio/Source" and
      (
        (.name | test("linein"; "i")) or
        (.nick | test("line.?in"; "i")) or
        (.desc | test("line.?in"; "i")) or
        (.object_path | test("linein|line-in"; "i"))
      )
    ))
    | sort_by(
        (if (.name | test("linein"; "i")) then 0 else 1 end),
        (if (.nick | test("line.?in"; "i")) then 0 else 1 end),
        .name
      )
    | .[0] // empty
    ' <<<"$nodes_json"
  )
fi

if [[ -z "$linein" ]]; then
  linein=$(
    jq -cr '
      map(select(
        .media_class == "Audio/Source" and
        (
          (.name | test("analog-stereo"; "i")) or
          (.object_path | test("analog-stereo"; "i"))
        ) and
        (
          (.name | test("usb"; "i") | not) and
          (.nick | test("usb|webcam|camera|headset|microphone|mic"; "i") | not) and
          (.desc | test("usb|webcam|camera|headset|microphone|mic"; "i") | not)
        )
      ))
      | sort_by(.name)
      | .[0] // empty
    ' <<<"$nodes_json"
  )
fi

if [[ -z "$linein" ]]; then
  printf 'No suitable line-in source node detected.\n' >&2
  exit 2
fi

linein_name=$(jq -r '.name' <<<"$linein")
linein_nick=$(jq -r '.nick' <<<"$linein")
linein_id=$(jq -r '.id' <<<"$linein")

default_sink_name=$(
  wpctl inspect @DEFAULT_AUDIO_SINK@ 2>/dev/null | jq -Rsr '
    split("\n")
    | map(select(test("node.name = ")))
    | .[0] // ""
    | sub(".*node.name = \""; "")
    | sub("\".*"; "")
  '
)

if [[ -z "$default_sink_name" ]]; then
  default_sink_name=$(jq -r '
    map(select(.media_class == "Audio/Sink"))
    | sort_by(.name)
    | .[0].name // empty
  ' <<<"$nodes_json")
fi

if [[ "$default_sink_name" == "$VISIBLE_SINK_NAME" ]]; then
  default_sink_name=$(jq -r --arg visible_sink "$VISIBLE_SINK_NAME" '
    map(select(
      .media_class == "Audio/Sink" and
      .name != $visible_sink and
      (.name | test("alsa_output|bluez_output"; "i"))
    ))
    | sort_by(.name)
    | .[0].name // empty
  ' <<<"$nodes_json")
fi

if [[ -z "$default_sink_name" ]]; then
  printf 'No default sink could be determined.\n' >&2
  exit 3
fi

cat > "$TMP_FILE" <<EOF
# Generated by linein-passthrough-refresh.
# This file is intentionally static PipeWire configuration for persistence.
# Re-run linein-passthrough refresh if your line-in node name changes.

context.modules = [
  {
    name = libpipewire-module-loopback
    args = {
      node.name = "${VISIBLE_SINK_NAME}"
      node.description = "${VISIBLE_SINK_NICK}"
      audio.rate = 48000
      audio.channels = 2
      audio.position = [ FL FR ]
      capture.props = {
        node.name = "${VISIBLE_SINK_NAME}"
        node.description = "${VISIBLE_SINK_NICK}"
        node.nick = "${VISIBLE_SINK_NICK}"
        media.name = "${VISIBLE_SINK_NICK}"
        media.class = "Audio/Sink"
        node.virtual = true
        audio.position = [ FL FR ]
      }
      playback.props = {
        node.name = "playback.${VISIBLE_SINK_NAME}"
        node.group = "${VISIBLE_SINK_NICK}"
        node.link-group = "${VISIBLE_SINK_NICK}"
        node.description = "${VISIBLE_SINK_NICK}"
        media.name = "${VISIBLE_SINK_NICK}"
        node.passive = true
        node.dont-reconnect = true
        audio.position = [ FL FR ]
        stream.dont-remix = true
      }
    }
  }
  {
    name = libpipewire-module-loopback
    args = {
      node.description = "${VISIBLE_SINK_NICK} Feed"
      audio.rate = 48000
      audio.channels = 2
      audio.position = [ FL FR ]
      capture.props = {
        node.name = "${FEED_CAPTURE_NAME}"
        node.group = "${VISIBLE_SINK_NICK}"
        node.link-group = "${VISIBLE_SINK_NICK}"
        target.object = "${linein_name}"
        node.passive = true
        node.dont-reconnect = true
        stream.dont-remix = true
      }
      playback.props = {
        node.name = "${FEED_PLAYBACK_NAME}"
        node.group = "${VISIBLE_SINK_NICK}"
        node.link-group = "${VISIBLE_SINK_NICK}"
        target.object = "${VISIBLE_SINK_NAME}"
        node.passive = true
        node.dont-reconnect = true
        stream.dont-remix = true
      }
    }
  }
  {
    name = libpipewire-module-loopback
    args = {
      node.description = "${VISIBLE_SINK_NICK} Direct"
      audio.rate = 48000
      audio.channels = 2
      audio.position = [ FL FR ]
      capture.props = {
        node.name = "${DIRECT_CAPTURE_NAME}"
        node.group = "${VISIBLE_SINK_NICK}"
        node.link-group = "${VISIBLE_SINK_NICK}"
        target.object = "${linein_name}"
        node.dont-reconnect = true
        stream.dont-remix = true
      }
      playback.props = {
        node.name = "${DIRECT_PLAYBACK_NAME}"
        node.group = "${VISIBLE_SINK_NICK}"
        node.link-group = "${VISIBLE_SINK_NICK}"
        target.object = "${default_sink_name}"
        node.dont-reconnect = true
        stream.dont-remix = true
      }
    }
  }
]
EOF

changed=1
if [[ -f "$CONFIG_FILE" ]] && cmp -s "$TMP_FILE" "$CONFIG_FILE"; then
  changed=0
else
  install -Dm0644 "$TMP_FILE" "$CONFIG_FILE"
fi
rm -f "$TMP_FILE"

cat > "$STATE_FILE" <<EOF
enabled=1
detected_node_name='${linein_name//\'/\'\\\'\'}'
detected_node_nick='${linein_nick//\'/\'\\\'\'}'
default_sink_name='${default_sink_name//\'/\'\\\'\'}'
virtual_sink_name='${VISIBLE_SINK_NAME}'
virtual_sink_nick='${VISIBLE_SINK_NICK}'
detected_node_id='${linein_id}'
EOF

if (( ACTIVATE == 1 )) && (( changed == 1 )); then
  systemctl --user restart --no-block pipewire.service wireplumber.service
fi

# Default the analog line-in capture volume to a safer level to reduce clipping.
pactl set-source-volume "$linein_name" 35% >/dev/null 2>&1 || true

printf 'line-in node: %s\n' "$linein_name"
if [[ -n "$linein_nick" ]]; then
  printf 'line-in nick: %s\n' "$linein_nick"
fi
printf 'virtual sink: %s\n' "$VISIBLE_SINK_NAME"
printf 'default sink: %s\n' "$default_sink_name"
if (( changed == 1 )); then
  printf 'config updated: %s\n' "$CONFIG_FILE"
else
  printf 'config unchanged\n'
fi
