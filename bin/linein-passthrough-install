#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR=$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)
PROJECT_ROOT=$(cd -- "${SCRIPT_DIR}/.." && pwd)
PREFIX=${XDG_CONFIG_HOME:-"${HOME}/.config"}
BIN_DIR=${HOME}/.local/bin
SYSTEMD_DIR=${PREFIX}/systemd/user
PIPEWIRE_DIR=${PREFIX}/pipewire/pipewire.conf.d
WIREPLUMBER_CONF_DIR=${PREFIX}/wireplumber/wireplumber.conf.d
WIREPLUMBER_SCRIPT_DIR=${HOME}/.local/share/wireplumber/scripts

usage() {
  cat <<'EOF'
Usage: linein-passthrough-install [--with-wireplumber-lua] [--without-service]

Installs linein-passthrough into the current user profile.

Options:
  --with-wireplumber-lua  Install the optional WirePlumber Lua helper.
  --without-service       Install configs and CLI only.
  -h, --help              Show this help.
EOF
}

install_wireplumber_lua=0
install_service=1

while (($# > 0)); do
  case "$1" in
    --with-wireplumber-lua)
      install_wireplumber_lua=1
      ;;
    --without-service)
      install_service=0
      ;;
    -h|--help)
      usage
      exit 0
      ;;
    *)
      printf 'Unknown option: %s\n' "$1" >&2
      usage >&2
      exit 1
      ;;
  esac
  shift
done

require_cmd() {
  local cmd=$1
  if ! command -v "$cmd" >/dev/null 2>&1; then
    printf 'Missing required command: %s\n' "$cmd" >&2
    exit 1
  fi
}

copy_file() {
  local src=$1
  local dst=$2
  install -Dm0644 "$src" "$dst"
}

copy_exec() {
  local src=$1
  local dst=$2
  install -Dm0755 "$src" "$dst"
}

require_cmd install
require_cmd systemctl
require_cmd wpctl
require_cmd pw-cli
require_cmd jq
require_cmd pactl

mkdir -p "$BIN_DIR" "$SYSTEMD_DIR" "$PIPEWIRE_DIR"

copy_exec "${PROJECT_ROOT}/bin/linein-passthrough" "${BIN_DIR}/linein-passthrough"
copy_exec "${PROJECT_ROOT}/libexec/linein-passthrough-refresh" "${BIN_DIR}/linein-passthrough-refresh"
copy_exec "${PROJECT_ROOT}/bin/linein-passthrough-uninstall" "${BIN_DIR}/linein-passthrough-uninstall"
copy_file "${PROJECT_ROOT}/config/pipewire/90-linein-passthrough.conf.disabled" "${PIPEWIRE_DIR}/90-linein-passthrough.conf.disabled"

if (( install_service == 1 )); then
  copy_file "${PROJECT_ROOT}/systemd/linein-passthrough-refresh.service" "${SYSTEMD_DIR}/linein-passthrough-refresh.service"
fi

if (( install_wireplumber_lua == 1 )); then
  mkdir -p "$WIREPLUMBER_CONF_DIR" "$WIREPLUMBER_SCRIPT_DIR"
  copy_file "${PROJECT_ROOT}/config/wireplumber/90-linein-passthrough.conf" "${WIREPLUMBER_CONF_DIR}/90-linein-passthrough.conf"
  rm -f "${WIREPLUMBER_SCRIPT_DIR}/90-linein-passthrough.lua"
fi

if (( install_service == 1 )); then
  systemctl --user daemon-reload
  systemctl --user enable linein-passthrough-refresh.service
fi

"${BIN_DIR}/linein-passthrough" enable

printf '\nInstalled linein-passthrough.\n'
printf 'CLI: %s\n' "${BIN_DIR}/linein-passthrough"
printf 'Uninstall: %s\n' "${BIN_DIR}/linein-passthrough-uninstall"
printf 'Status: run `linein-passthrough status`\n'

if (( install_wireplumber_lua == 1 )); then
  printf 'WirePlumber placeholder config installed. No Lua helper is currently needed.\n'
fi
